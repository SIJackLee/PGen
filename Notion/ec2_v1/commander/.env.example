# Commander 환경변수 (EC2)

# MQTT (DOWNLINK 발행, STATE_ACK 구독)
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=commander_v1

# Redis (cmd:ack)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
QUEUE_CMD_ACK=cmd:ack

# Supabase REST (room_command_queue_v3)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 설정
SCAN_INTERVAL=5.0
ACK_INTERVAL=1.0
LOG_LEVEL=INFO
