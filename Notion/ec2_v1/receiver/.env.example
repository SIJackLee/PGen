# Receiver 환경변수 설정 (EC2)

# MQTT 브로커
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=receiver_v2

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Redis 큐
QUEUE_RAW=rx:v2:raw
QUEUE_CMD_ACK=cmd:ack

# 설정
MAX_CMD_PER_ACK=3
MAX_PRINT_PER_SEC=2.0
LOG_LEVEL=INFO
